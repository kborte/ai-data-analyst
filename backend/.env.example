APP_NAME=ai-data-analyst-backend
ENV=development
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=storage/uploads
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_data_analyst
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Storage — set STORAGE_BACKEND=supabase and fill Supabase vars for production.
# Leave STORAGE_BACKEND=local for dev/tests (no Supabase account needed).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=ai-data-analyst
STORAGE_TEMP_DIR=/tmp/ai_data_analyst
